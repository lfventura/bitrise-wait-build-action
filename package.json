{
  "name": "bitrise-wait-build-action",
  "version": "1.0.6",
  "description": "A GitHub Action to wait for a Bitrise build to finish",
  "main": "dist/index.ts",
  "scripts": {
    "test": "npx jest",
    "lint": "eslint src/**/*.ts",
    "lintfix": "eslint src/**/*.ts --fix",
    "build": "ncc build src/index.ts --out dist",
    "local-test": "npx local-action . src/run.ts .env"
  },
  "keywords": [
    "github",
    "actions",
    "module"
  ],
  "author": "Lucas Ventura",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@github/local-action": "github:github/local-action",
    "@types/jest": "^29.5.14",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.1"
  },
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "undici": "6.27.0",
    "brace-expansion": "^1.1.12",
    "@actions/http-client": "^2.2.3",
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "fast-xml-builder": "1.2.0",
    "fast-xml-parser": "5.9.3"
  }
}
